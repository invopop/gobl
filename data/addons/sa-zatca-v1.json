{
  "$schema": "https://gobl.org/draft-0/tax/addon-def",
  "key": "sa-zatca-v1",
  "name": {
    "ar": "هيئة الزكاة والضريبة والجمارك",
    "en": "Saudi Arabia ZATCA"
  },
  "description": {
    "en": "Support for the Saudi Arabia ZATCA (Zakat, Tax and Customs Authority) e-invoicing\nrequirements based on UBL 2.1 with EN 16931 as an intermediate layer and KSA-specific\nextensions (BR-KSA-* rules).\n\nZATCA e-invoicing covers both standard tax invoices (B2B/B2G) sent for clearance\nand simplified tax invoices (B2C) sent for reporting through the FATOORA platform.\n\nThis addon extends EN 16931 with Saudi-specific fields and validations including\ninvoice type transactions, address requirements, and supply date handling."
  },
  "sources": [
    {
      "title": {
        "en": "ZATCA E-Invoicing Developer Portal"
      },
      "url": "https://zatca.gov.sa/en/E-Invoicing/SystemsDevelopers/Pages/E-Invoice-specifications.aspx"
    }
  ],
  "extensions": [
    {
      "key": "sa-zatca-invoice-type",
      "name": {
        "ar": "نوع الفاتورة",
        "en": "ZATCA Invoice Type"
      },
      "desc": {
        "en": "Code used to describe the ZATCA invoice subtype and transaction flags (KSA-2).\nThe code is a 7-character string where positions 1-2 indicate the main type\n(01 = Standard Tax Invoice, 02 = Simplified Tax Invoice) and positions 3-7\nare binary flags for third-party, nominal, export, summary, and self-billed\ntransactions respectively."
      },
