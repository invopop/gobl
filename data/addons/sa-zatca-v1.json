        }
      ],
      "pattern": "^0[12][01]{5}$"
    },
    {
      "key": "sa-zatca-seller-id-scheme",
      "name": {
        "ar": "نظام تعريف البائع",
        "en": "ZATCA Seller Identification Scheme"
      },
      "desc": {
        "en": "Scheme ID for the seller's additional identification (BT-29-1).\nOne of: CRN (Commercial Registration), MOM (MOMRAH license),\nMLS (MHRSD license), 700 (700 Number), SAG (MISA license),\nOTH (Other ID)."
      },
      "values": [
        {
          "code": "CRN",
          "name": {
            "ar": "رقم السجل التجاري",
            "en": "Commercial Registration Number"
          }
        },
        {
          "code": "MOM",
          "name": {
            "ar": "ترخيص وزارة الشؤون البلدية",
            "en": "MOMRAH License"
