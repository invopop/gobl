{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gobl.org/draft-0/org/person",
  "$ref": "#/$defs/Person",
  "$defs": {
    "Address": {
      "$id": "https://gobl.org/draft-0/org/address",
      "properties": {
        "uuid": {
          "type": "string",
          "format": "uuid",
          "title": "UUID",
          "description": "Universally Unique Identifier."
        },
        "label": {
          "type": "string",
          "title": "Label",
          "description": "Useful identifier, such as home, work, etc.",
          "examples": [
            "Office"
          ]
        },
        "po_box": {
          "type": "string",
          "title": "Post Office Box",
          "description": "Box number or code for the post office box located at the address."
        },
        "num": {
          "type": "string",
          "title": "Number",
          "description": "House or building number in the street."
        },
        "floor": {
          "type": "string",
          "title": "Floor",
          "description": "Floor number within the building."
        },
        "block": {
          "type": "string",
          "title": "Block",
          "description": "Block number within the building."
        },
        "door": {
          "type": "string",
          "title": "Door",
          "description": "Door number within the building."
        },
        "street": {
          "type": "string",
          "title": "Street",
          "description": "First line of street."
        },
        "street_extra": {
          "type": "string",
          "title": "Extended Street",
          "description": "Additional street address details."
        },
        "locality": {
          "type": "string",
          "title": "Locality",
          "description": "Name of a village, town, district, or city, typically inside a region."
        },
        "region": {
          "type": "string",
          "title": "Region",
          "description": "Name of a city, province, county, or state, inside a country."
        },
        "state": {
          "$ref": "https://gobl.org/draft-0/cbc/code",
          "title": "State",
          "description": "State or province code for countries that require it."
        },
        "code": {
          "$ref": "https://gobl.org/draft-0/cbc/code",
          "title": "Code",
          "description": "Post or ZIP code."
        },
        "country": {
          "$ref": "https://gobl.org/draft-0/l10n/iso-country-code",
          "title": "Country",
          "description": "ISO country code."
        },
        "coords": {
          "$ref": "https://gobl.org/draft-0/org/coordinates",
          "title": "Coordinates",
          "description": "When the postal address is not sufficient, coordinates help locate the address more precisely."
        },
        "meta": {
          "$ref": "https://gobl.org/draft-0/cbc/meta",
          "title": "Meta",
          "description": "Any additional semi-structure details about the address."
        }
      },
      "type": "object",
      "description": "Address defines a globally acceptable set of attributes that describes a postal or fiscal address.",
      "recommended": [
        "number",
        "street",
        "locality",
        "region",
        "code",
        "country"
      ]
    },
    "Code": {
      "$id": "https://gobl.org/draft-0/cbc/code",
      "type": "string",
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^[A-ZÑa-z0-9]+([\\.\\-\\:/,_\\\u0026 ]?[A-ZÑa-z0-9]+)*$",
      "title": "Code",
      "description": "Alphanumerical text identifier with upper-case letters and limits on using\nspecial characters or whitespace to separate blocks."
    },
    "Coordinates": {
      "$id": "https://gobl.org/draft-0/org/coordinates",
      "properties": {
        "lat": {
          "type": "number",
          "title": "Latitude",
          "description": "Decimal latitude coordinate."
        },
        "lon": {
          "type": "number",
          "title": "Longitude",
          "description": "Decimal longitude coordinate."
        },
        "w3w": {
          "type": "string",
          "title": "What 3 Words",
          "description": "What 3 Words text coordinates."
        },
        "geohash": {
          "type": "string",
          "title": "Geohash",
          "description": "Single string coordinate based on geohash standard."
        }
      },
      "type": "object",
      "description": "Coordinates describes an exact geographical location in the world."
    },
    "Digest": {
      "$id": "https://gobl.org/draft-0/dsig/digest",
      "properties": {
        "alg": {
          "type": "string",
          "title": "Algorithm",
          "description": "Algorithm stores the algorithm key that was used to generate the value."
        },
        "val": {
          "type": "string",
          "title": "Value",
          "description": "Value contains the Hexadecimal representation of the resulting hash\ngenerated by the algorithm."
        }
      },
      "type": "object",
      "required": [
        "alg",
        "val"
      ],
      "description": "Digest defines a structure to hold a digest value including the algorithm used to generate it."
    },
    "Email": {
      "$id": "https://gobl.org/draft-0/org/email",
      "properties": {
        "uuid": {
          "type": "string",
          "format": "uuid",
          "title": "UUID",
          "description": "Universally Unique Identifier."
        },
        "label": {
          "type": "string",
          "title": "Label",
          "description": "Identifier for the email."
        },
        "addr": {
          "type": "string",
          "title": "Address",
          "description": "Electronic mailing address."
        },
        "meta": {
          "$ref": "https://gobl.org/draft-0/cbc/meta",
          "title": "Meta",
          "description": "Additional fields."
        }
      },
      "type": "object",
      "required": [
        "addr"
      ],
      "description": "Email describes the electronic mailing details."
    },
    "Extensions": {
      "$id": "https://gobl.org/draft-0/tax/extensions",
      "patternProperties": {
        "^(?:[a-z]|[a-z0-9][a-z0-9-+]*[a-z0-9])$": {
          "$ref": "https://gobl.org/draft-0/cbc/code"
        }
      },
      "type": "object",
      "description": "Extensions is a map of extension keys to values."
    },
