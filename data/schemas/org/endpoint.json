{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gobl.org/draft-0/org/endpoint",
  "$ref": "#/$defs/org.Endpoint",
  "$defs": {
    "org.Endpoint": {
      "properties": {
        "uuid": {
          "type": "string",
          "format": "uuid",
          "title": "UUID",
          "description": "Universally Unique Identifier."
        },
        "label": {
          "type": "string",
          "title": "Label",
          "description": "Label for the endpoint."
        },
        "uri": {
          "$ref": "https://gobl.org/draft-0/cbc/uri",
          "title": "URI",
          "description": "URI that identifies the endpoint."
        }
      },
      "type": "object",
      "required": [
        "uri"
      ],
      "description": "Endpoint identifies an address to which electronic documents may be sent, expressed as a single URI."
    }
  }
}