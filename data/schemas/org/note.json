{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gobl.org/draft-0/org/note",
  "$ref": "#/$defs/Note",
  "$defs": {
    "Code": {
      "$id": "https://gobl.org/draft-0/cbc/code",
      "type": "string",
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^[A-ZÑa-z0-9]+([\\.\\-\\:/,_\\\u0026 ]?[A-ZÑa-z0-9]+)*$",
      "title": "Code",
      "description": "Alphanumerical text identifier with upper-case letters and limits on using\nspecial characters or whitespace to separate blocks."
    },
    "Extensions": {
      "$id": "https://gobl.org/draft-0/tax/extensions",
      "patternProperties": {
        "^(?:[a-z]|[a-z0-9][a-z0-9-+]*[a-z0-9])$": {
          "$ref": "https://gobl.org/draft-0/cbc/code"
        }
      },
      "type": "object",
      "description": "Extensions is a map of extension keys to values."
    },
    "Key": {
      "$id": "https://gobl.org/draft-0/cbc/key",
      "type": "string",
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^(?:[a-z]|[a-z0-9][a-z0-9-+]*[a-z0-9])$",
      "title": "Key",
      "description": "Text identifier to be used instead of a code for a more verbose but readable identifier."
    },
    "Meta": {
      "$id": "https://gobl.org/draft-0/cbc/meta",
      "patternProperties": {
        "^(?:[a-z]|[a-z0-9][a-z0-9-+]*[a-z0-9])$": {
          "type": "string"
        }
      },
      "type": "object",
      "description": "Meta defines a structure for data about the data being defined."
    },
    "Note": {
      "properties": {
        "uuid": {
          "type": "string",
          "format": "uuid",
          "title": "UUID",
          "description": "Universally Unique Identifier."
        },
        "key": {
          "$ref": "https://gobl.org/draft-0/cbc/key",
          "oneOf": [
            {
              "const": "goods",
              "title": "Goods",
              "description": "Goods Description"
            },
            {
              "const": "payment",
              "title": "Payment",
              "description": "Terms of Payment"
            },
            {
              "const": "payment-method",
              "title": "Payment Method",
              "description": "Payment method or remittance information"
            },
            {
              "const": "payment-term",
              "title": "Payment Term",
              "description": "Payment term details"
            },
            {
              "const": "legal",
              "title": "Legal",
              "description": "Legal or regulatory information"
            },
            {
              "const": "dangerous-goods",
              "title": "Dangerous Goods",
              "description": "Dangerous goods additional information"
            },
            {
              "const": "ack",
              "title": "Acknowledgement",
              "description": "Acknowledgement Description"
            },
            {
              "const": "rate",
              "title": "Rate",
              "description": "Rate additional information"
            },
            {
              "const": "reason",
              "title": "Reason",
              "description": "Explanation of something relevant to the document"
            },
            {
              "const": "dispute",
              "title": "Dispute",
              "description": "Details on a dispute."
            },
            {
              "const": "customer",
              "title": "Customer",
              "description": "Customer remarks"
            },
            {
              "const": "glossary",
              "title": "Glossary",
              "description": "Glossary of terms"
            },
            {
              "const": "customs",
              "title": "Customs",
              "description": "Customs declaration information"
            },
            {
              "const": "general",
              "title": "General",
              "description": "General information"
            },
            {
              "const": "handling",
              "title": "Handling",
              "description": "Handling instructions"
            },
            {
              "const": "packaging",
              "title": "Packaging",
              "description": "Packaging information"
            },
            {
              "const": "loading",
              "title": "Loading",
              "description": "Loading instructions"
            },
            {
              "const": "price",
              "title": "Price",
              "description": "Price conditions"
            },
            {
              "const": "priority",
              "title": "Priority",
              "description": "Priority information"
            },
            {
              "const": "regulatory",
              "title": "Regulatory",
              "description": "Regulatory information"
            },
            {
              "const": "safety",
              "title": "Safety",
              "description": "Safety instructions"
            },
            {
              "const": "ship-line",
              "title": "Ship Line",
              "description": "Ship line"
            },
            {
              "const": "supplier",
              "title": "Supplier",
              "description": "Supplier remarks"
            },
            {
              "const": "transport",
              "title": "Transport",
              "description": "Transportation information"
            },
            {
              "const": "delivery",
              "title": "Delivery",
              "description": "Delivery information"
            },
            {
              "const": "quarantine",
              "title": "Quarantine",
              "description": "Quarantine information"
            },
            {
              "const": "tax",
              "title": "Tax",
              "description": "Tax declaration"
            },
            {
              "const": "other",
              "title": "Other",
              "description": "Mutually defined"
            }
          ],
          "title": "Key",
          "description": "Key specifying subject of the text"
        },
        "code": {
          "$ref": "https://gobl.org/draft-0/cbc/code",
          "title": "Code",
          "description": "Code used for additional data that may be required to identify the note."
        },
        "src": {
          "$ref": "https://gobl.org/draft-0/cbc/key",
          "title": "Source",
          "description": "Source of this note, especially useful when auto-generated."
        },
        "text": {
          "type": "string",
          "title": "Text",
          "description": "The contents of the note"
        },
        "meta": {
          "$ref": "https://gobl.org/draft-0/cbc/meta",
          "title": "Meta",
          "description": "Additional information about the note"
        },
        "ext": {
          "$ref": "https://gobl.org/draft-0/tax/extensions",
          "title": "Extensions",
          "description": "Extension data"
        }
      },
      "type": "object",
      "required": [
        "text"
      ],
      "description": "Note represents a free text of additional information that may be added to a document."
    }
  }
}