{
  "id": "GOBL-SA",
  "package": "sa",
  "subsets": [
    {
      "id": "GOBL-SA-ORG-IDENTITY",
      "object": "org.Identity",
      "subsets": [
        {
          "guard": "context: regime in [SA]",
          "subsets": [
            {
              "field": "code",
              "assert": [
                {
                  "id": "GOBL-SA-ORG-IDENTITY-01",
                  "desc": "SA identity code must be valid",
                  "tests": "matches ^[a-zA-Z0-9]*$"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-SA-TAX-IDENTITY",
      "object": "tax.Identity",
      "subsets": [
        {
          "guard": "code in [SA]",
          "subsets": [
            {
              "field": "code",
              "assert": [
                {
                  "id": "GOBL-SA-TAX-IDENTITY-01",
                  "desc": "VAT number must be 15 digits starting/ending with 3",
                  "tests": "matches ^3[0-9]{13}3$"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
