{
  "id": "GOBL-BR-NFE",
  "package": "br-nfe",
  "guard": "context: addon in [br-nfe-v4]",
  "subsets": [
    {
      "id": "GOBL-BR-NFE-BILL-INVOICE",
      "object": "bill.Invoice",
      "assert": [
        {
          "id": "GOBL-BR-NFE-BILL-INVOICE-34",
          "desc": "invoice currency must be BRL or provide exchange rate for conversion",
          "tests": "can convert to [BRL]"
        },
        {
          "id": "GOBL-BR-NFE-BILL-INVOICE-30",
          "desc": "invoice requires a note with key 'reason' to describe the nature of the operation (natOp)",
          "tests": "has reason note"
        }
      ],
      "subsets": [
        {
          "field": "supplier",
          "subsets": [
            {
              "field": "tax_id",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-BILL-INVOICE-01",
                  "desc": "invoice supplier tax ID is required",
                  "tests": "present"
                }
              ],
              "subsets": [
                {
                  "field": "code",
                  "assert": [
                    {
                      "id": "GOBL-BR-NFE-BILL-INVOICE-02",
                      "desc": "invoice supplier tax ID code is required",
                      "tests": "present"
                    }
                  ]
                }
              ]
            },
            {
              "field": "addresses",
              "subsets": [
                {
                  "each": true,
                  "assert": [
                    {
                      "id": "GOBL-BR-NFE-BILL-INVOICE-03",
                      "desc": "invoice supplier address must not be empty",
                      "tests": "present"
                    }
                  ],
                  "subsets": [
                    {
                      "field": "street",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-04",
                          "desc": "invoice supplier address requires a street",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "num",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-05",
                          "desc": "invoice supplier address requires a number",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "locality",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-06",
                          "desc": "invoice supplier address requires a locality",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "state",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-07",
                          "desc": "invoice supplier address requires a state",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "code",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-08",
                          "desc": "invoice supplier address requires a postal code",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "country",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-37",
                          "desc": "invoice supplier address requires a country",
                          "tests": "present"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "guard": "has addresses",
              "subsets": [
                {
                  "field": "ext",
                  "assert": [
                    {
                      "id": "GOBL-BR-NFE-BILL-INVOICE-09",
                      "desc": "invoice supplier requires 'br-ibge-municipality' extension when addresses are present",
                      "tests": "ext require [br-ibge-municipality]"
                    }
                  ]
                }
              ]
            },
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-BILL-INVOICE-39",
                  "desc": "invoice supplier requires 'br-nfe-regime' extension",
                  "tests": "ext require [br-nfe-regime]"
                }
              ]
            },
            {
              "field": "name",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-BILL-INVOICE-10",
                  "desc": "invoice supplier name is required",
                  "tests": "present"
                }
              ]
            },
            {
              "field": "addresses",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-BILL-INVOICE-11",
                  "desc": "invoice supplier must have at least one address",
                  "tests": "present"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice is NFe",
          "subsets": [
            {
              "field": "customer",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-BILL-INVOICE-12",
                  "desc": "invoice customer is required for NF-e invoices",
                  "tests": "present"
                }
              ],
              "subsets": [
                {
                  "field": "addresses",
                  "assert": [
                    {
                      "id": "GOBL-BR-NFE-BILL-INVOICE-13",
                      "desc": "invoice customer must have at least one address for NF-e invoices",
                      "tests": "present"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "customer",
          "subsets": [
            {
              "guard": "no tax ID",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-BILL-INVOICE-36",
                  "desc": "invoice customer must have a tax ID or a foreign country identity",
                  "tests": "has foreign country identity"
                }
              ]
            },
            {
              "field": "tax_id",
              "subsets": [
                {
                  "field": "code",
                  "assert": [
                    {
                      "id": "GOBL-BR-NFE-BILL-INVOICE-15",
                      "desc": "invoice customer tax ID code is required",
                      "tests": "present"
                    }
                  ]
                }
              ]
            },
            {
              "field": "addresses",
              "subsets": [
                {
                  "each": true,
                  "assert": [
                    {
                      "id": "GOBL-BR-NFE-BILL-INVOICE-16",
                      "desc": "invoice customer address must not be empty",
                      "tests": "present"
                    }
                  ],
                  "subsets": [
                    {
                      "field": "street",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-17",
                          "desc": "invoice customer address requires a street",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "num",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-18",
                          "desc": "invoice customer address requires a number",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "locality",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-19",
                          "desc": "invoice customer address requires a locality",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "code",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-21",
                          "desc": "invoice customer address requires a postal code",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "country",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-38",
                          "desc": "invoice customer address requires a country",
                          "tests": "present"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "guard": "is Brazilian",
              "subsets": [
                {
                  "field": "addresses",
                  "subsets": [
                    {
                      "each": true,
                      "subsets": [
                        {
                          "field": "state",
                          "assert": [
                            {
                              "id": "GOBL-BR-NFE-BILL-INVOICE-20",
                              "desc": "invoice customer address requires a state",
                              "tests": "present"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "guard": "has addresses",
                  "subsets": [
                    {
                      "field": "ext",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-22",
                          "desc": "invoice customer requires 'br-ibge-municipality' extension when addresses are present",
                          "tests": "ext require [br-ibge-municipality]"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "series",
          "assert": [
            {
              "id": "GOBL-BR-NFE-BILL-INVOICE-23",
              "desc": "invoice series is required",
              "tests": "present"
            },
            {
              "id": "GOBL-BR-NFE-BILL-INVOICE-24",
              "desc": "invoice series format is invalid; must be 0 or 1-999",
              "tests": "matches ^(?:0|[1-9]{1}[0-9]{0,2})$"
            }
          ]
        },
        {
          "field": "tax",
          "assert": [
            {
              "id": "GOBL-BR-NFE-BILL-INVOICE-25",
              "desc": "invoice tax is required",
              "tests": "present"
            }
          ],
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-BILL-INVOICE-26",
                  "desc": "invoice tax requires 'br-nfe-model' and 'br-nfe-presence' extensions",
                  "tests": "ext require [br-nfe-model, br-nfe-presence]"
                }
              ],
              "subsets": [
                {
                  "guard": "NFe model",
                  "assert": [
                    {
                      "id": "GOBL-BR-NFE-BILL-INVOICE-27",
                      "desc": "NF-e invoices do not support '4' for 'br-nfe-presence'",
                      "tests": "ext 'br-nfe-presence' not in [4]"
                    }
                  ]
                },
                {
                  "guard": "NFCe model",
                  "assert": [
                    {
                      "id": "GOBL-BR-NFE-BILL-INVOICE-28",
                      "desc": "NFC-e invoices require in-person or delivery for 'br-nfe-presence'",
                      "tests": "ext 'br-nfe-presence' in [1, 4]"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "notes",
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "guard": "reason note",
                  "subsets": [
                    {
                      "field": "text",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-29",
                          "desc": "invoice reason note text must be between 1 and 60 characters",
                          "tests": "length between 1 and 60"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice not paid",
          "subsets": [
            {
              "field": "payment",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-BILL-INVOICE-31",
                  "desc": "invoice payment is required when invoice is unpaid",
                  "tests": "present"
                }
              ],
              "subsets": [
                {
                  "field": "instructions",
                  "assert": [
                    {
                      "id": "GOBL-BR-NFE-BILL-INVOICE-32",
                      "desc": "invoice payment instructions are required when invoice is unpaid",
                      "tests": "present"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "totals",
          "subsets": [
            {
              "field": "due",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-BILL-INVOICE-33",
                  "desc": "invoice due amount must not be negative",
                  "tests": "zero or positive"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice is NFe",
          "subsets": [
            {
              "field": "lines",
              "subsets": [
                {
                  "each": true,
                  "subsets": [
                    {
                      "field": "ext",
                      "assert": [
                        {
                          "id": "GOBL-BR-NFE-BILL-INVOICE-35",
                          "desc": "NF-e invoice lines require 'br-nfe-cfop' extension",
                          "tests": "ext require [br-nfe-cfop]"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BR-NFE-BILL-LINE",
      "object": "bill.Line",
      "assert": [
        {
          "id": "GOBL-BR-NFE-BILL-LINE-01",
          "desc": "line taxes must include the ICMS category",
          "tests": "line has tax category ICMS"
        },
        {
          "id": "GOBL-BR-NFE-BILL-LINE-02",
          "desc": "line taxes must include the PIS category",
          "tests": "line has tax category PIS"
        },
        {
          "id": "GOBL-BR-NFE-BILL-LINE-03",
          "desc": "line taxes must include the COFINS category",
          "tests": "line has tax category COFINS"
        }
      ]
    },
    {
      "id": "GOBL-BR-NFE-TAX-COMBO",
      "object": "tax.Combo",
      "subsets": [
        {
          "guard": "ICMS category",
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-TAX-COMBO-01",
                  "desc": "ICMS tax combo requires 'br-nfe-icms-cst' or 'br-nfe-icms-csosn' extension",
                  "tests": "ext require [br-nfe-icms-cst], or ext require [br-nfe-icms-csosn]"
                },
                {
                  "id": "GOBL-BR-NFE-TAX-COMBO-02",
                  "desc": "ICMS tax combo requires 'br-nfe-icms-origin' extension",
                  "tests": "ext require [br-nfe-icms-origin]"
                }
              ]
            }
          ]
        },
        {
          "guard": "PIS category",
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-TAX-COMBO-03",
                  "desc": "PIS tax combo requires 'br-nfe-pis-cst' extension",
                  "tests": "ext require [br-nfe-pis-cst]"
                }
              ]
            }
          ]
        },
        {
          "guard": "COFINS category",
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-BR-NFE-TAX-COMBO-04",
                  "desc": "COFINS tax combo requires 'br-nfe-cofins-cst' extension",
                  "tests": "ext require [br-nfe-cofins-cst]"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BR-NFE-PAY-INSTRUCTIONS",
      "object": "pay.Instructions",
      "subsets": [
        {
          "field": "ext",
          "assert": [
            {
              "id": "GOBL-BR-NFE-PAY-INSTRUCTIONS-01",
              "desc": "payment instructions require 'br-nfe-payment-means' extension",
              "tests": "ext require [br-nfe-payment-means]"
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BR-NFE-PAY-RECORD",
      "object": "pay.Record",
      "subsets": [
        {
          "field": "ext",
          "assert": [
            {
              "id": "GOBL-BR-NFE-PAY-RECORD-01",
              "desc": "payment advance requires 'br-nfe-payment-means' extension",
              "tests": "ext require [br-nfe-payment-means]"
            }
          ]
        }
      ]
    }
  ]
}
