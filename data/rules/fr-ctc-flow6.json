{
  "id": "GOBL-FR-CTC-FLOW6",
  "package": "fr-ctc-flow6",
  "guard": "context: addon in [fr-ctc-flow6-v1]",
  "subsets": [
    {
      "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS",
      "object": "bill.Status",
      "subsets": [
        {
          "field": "type",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-01",
              "desc": "status type must be one of: response, update",
              "tests": "one of [response, update]"
            }
          ]
        },
        {
          "field": "ext",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-02",
              "desc": "status ext fr-ctc-flow6-status must be a Status-applicable ProcessConditionCode (200-210 or 213); codes 211, 212 belong on bill.Payment",
              "tests": "ext 'fr-ctc-flow6-status' in [200, 201, 202, 203, 204, 205, 206, 207, 208, 209, 210, 213]"
            }
          ]
        },
        {
          "field": "supplier",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-03",
              "desc": "status supplier is required (BR-FR-CDV-13)",
              "tests": "present"
            },
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-04",
              "desc": "status supplier must have an inbox when its role is not WK or DFH (BR-FR-CDV-08)",
              "tests": "supplier has inbox unless WK/DFH"
            }
          ],
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-05",
                  "desc": "status supplier ext fr-ctc-flow6-role is required (BR-FR-CDV-CL-03)",
                  "tests": "ext require [fr-ctc-flow6-role]"
                }
              ]
            },
            {
              "field": "identities",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-06",
                  "desc": "status supplier must have an identity with ISO/IEC 6523 scheme 0002 (SIREN)",
                  "tests": "has a ext [iso-scheme-id] in [0002]"
                }
              ]
            }
          ]
        },
        {
          "field": "customer",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-07",
              "desc": "status customer is required (BR-FR-CDV-CL-04)",
              "tests": "present"
            },
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-08",
              "desc": "status customer must have an inbox when its role is not WK or DFH (BR-FR-CDV-08)",
              "tests": "customer has inbox unless WK/DFH"
            }
          ],
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-09",
                  "desc": "status customer ext fr-ctc-flow6-role is required (BR-FR-CDV-CL-04)",
                  "tests": "ext require [fr-ctc-flow6-role]"
                }
              ]
            },
            {
              "field": "identities",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-10",
                  "desc": "status customer must have at least one identity with an iso-scheme-id in the Flow 6 allow-list; STC 0231 is a Flow 2 invoice concept",
                  "tests": "has a ext [iso-scheme-id] in [0002, 0009, 0223, 0224, 0226, 0227, 0228, 0229, 0238]"
                }
              ]
            }
          ]
        },
        {
          "field": "lines",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-11",
              "desc": "status lines must contain exactly one entry",
              "tests": "present, length between 1 and 1"
            }
          ],
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "field": "doc",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-12",
                      "desc": "status line doc is required (BR-FR-CDV-10)",
                      "tests": "present"
                    }
                  ],
                  "subsets": [
                    {
                      "field": "code",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-13",
                          "desc": "status line doc code is required (BR-FR-CDV-10)",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "issue_date",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-14",
                          "desc": "status line doc issue_date is required (BR-FR-CDV-11)",
                          "tests": "present"
                        }
                      ]
                    }
                  ]
                },
                {
                  "field": "key",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-15",
                      "desc": "status line key must be a recognised Flow 6 event",
                      "tests": "one of [issued, acknowledged, processing, accepted, querying, rejected, error]"
                    }
                  ]
                },
                {
                  "guard": "status line key in [rejected, querying, error]",
                  "subsets": [
                    {
                      "field": "reasons",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-16",
                          "desc": "status line reasons require at least one entry when key is rejected, querying or error (BR-FR-CDV-14)",
                          "tests": "present"
                        }
                      ]
                    }
                  ]
                },
                {
                  "guard": "line status code 200",
                  "subsets": [
                    {
                      "field": "reasons",
                      "subsets": [
                        {
                          "each": true,
                          "subsets": [
                            {
                              "field": "ext",
                              "assert": [
                                {
                                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-17",
                                  "desc": "status line reason ext fr-ctc-flow6-reason for status code 200 (Déposée — transmission rejection) must be NON_TRANSMISE (BR-FR-CDV-CL-09)",
                                  "tests": "ext 'fr-ctc-flow6-reason' in [NON_TRANSMISE]"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "guard": "line status code 206",
                  "subsets": [
                    {
                      "field": "reasons",
                      "subsets": [
                        {
                          "each": true,
                          "subsets": [
                            {
                              "field": "ext",
                              "assert": [
                                {
                                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-18",
                                  "desc": "status line reason ext fr-ctc-flow6-reason for status code 206 (Approuvée partiellement) must be one of AUTRE, CMD_ERR, SIRET_ERR, CODE_ROUTAGE_ERR, REF_CT_ABSENT, REF_ERR, PU_ERR, REM_ERR, QTE_ERR, ART_ERR, MODPAI_ERR, QUALITE_ERR, LIVR_INCOMP (BR-FR-CDV-CL-09)",
                                  "tests": "ext 'fr-ctc-flow6-reason' in [AUTRE, CMD_ERR, SIRET_ERR, CODE_ROUTAGE_ERR, REF_CT_ABSENT, REF_ERR, PU_ERR, REM_ERR, QTE_ERR, ART_ERR, MODPAI_ERR, QUALITE_ERR, LIVR_INCOMP]"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "guard": "line status code 207",
                  "subsets": [
                    {
                      "field": "reasons",
                      "subsets": [
                        {
                          "each": true,
                          "subsets": [
                            {
                              "field": "ext",
                              "assert": [
                                {
                                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-19",
                                  "desc": "status line reason ext fr-ctc-flow6-reason for status code 207 (En litige) must be one of AUTRE, COORD_BANC_ERR, TX_TVA_ERR, MONTANTTOTAL_ERR, CALCUL_ERR, NON_CONFORME, DOUBLON, DEST_ERR, TRANSAC_INC, EMMET_INC, CONTRAT_TERM, DOUBLE_FACT, CMD_ERR, ADR_ERR, SIRET_ERR, CODE_ROUTAGE_ERR, REF_CT_ABSENT, REF_ERR, PU_ERR, REM_ERR, QTE_ERR, ART_ERR, MODPAI_ERR, QUALITE_ERR, LIVR_INCOMP (BR-FR-CDV-CL-09)",
                                  "tests": "ext 'fr-ctc-flow6-reason' in [AUTRE, COORD_BANC_ERR, TX_TVA_ERR, MONTANTTOTAL_ERR, CALCUL_ERR, NON_CONFORME, DOUBLON, DEST_ERR, TRANSAC_INC, EMMET_INC, CONTRAT_TERM, DOUBLE_FACT, CMD_ERR, ADR_ERR, SIRET_ERR, CODE_ROUTAGE_ERR, REF_CT_ABSENT, REF_ERR, PU_ERR, REM_ERR, QTE_ERR, ART_ERR, MODPAI_ERR, QUALITE_ERR, LIVR_INCOMP]"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "guard": "line status code 208",
                  "subsets": [
                    {
                      "field": "reasons",
                      "subsets": [
                        {
                          "each": true,
                          "subsets": [
                            {
                              "field": "ext",
                              "assert": [
                                {
                                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-20",
                                  "desc": "status line reason ext fr-ctc-flow6-reason for status code 208 (Suspendue) must be one of JUSTIF_ABS, COORD_BANC_ERR, CMD_ERR, SIRET_ERR, CODE_ROUTAGE_ERR, REF_CT_ABSENT, REF_ERR (BR-FR-CDV-CL-09)",
                                  "tests": "ext 'fr-ctc-flow6-reason' in [JUSTIF_ABS, COORD_BANC_ERR, CMD_ERR, SIRET_ERR, CODE_ROUTAGE_ERR, REF_CT_ABSENT, REF_ERR]"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "guard": "line status code 210",
                  "subsets": [
                    {
                      "field": "reasons",
                      "subsets": [
                        {
                          "each": true,
                          "subsets": [
                            {
                              "field": "ext",
                              "assert": [
                                {
                                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-21",
                                  "desc": "status line reason ext fr-ctc-flow6-reason for status code 210 (Refusée) must be one of TX_TVA_ERR, MONTANTTOTAL_ERR, CALCUL_ERR, NON_CONFORME, DOUBLON, DEST_ERR, TRANSAC_INC, EMMET_INC, CONTRAT_TERM, DOUBLE_FACT, CMD_ERR, ADR_ERR, REF_CT_ABSENT (BR-FR-CDV-CL-09)",
                                  "tests": "ext 'fr-ctc-flow6-reason' in [TX_TVA_ERR, MONTANTTOTAL_ERR, CALCUL_ERR, NON_CONFORME, DOUBLON, DEST_ERR, TRANSAC_INC, EMMET_INC, CONTRAT_TERM, DOUBLE_FACT, CMD_ERR, ADR_ERR, REF_CT_ABSENT]"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "guard": "line status code 213",
                  "subsets": [
                    {
                      "field": "reasons",
                      "subsets": [
                        {
                          "each": true,
                          "subsets": [
                            {
                              "field": "ext",
                              "assert": [
                                {
                                  "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-22",
                                  "desc": "status line reason ext fr-ctc-flow6-reason for status code 213 (Rejetée sémantique) must be one of MONTANTTOTAL_ERR, CALCUL_ERR, DOUBLON, ADR_ERR, REJ_SEMAN, REJ_UNI, REJ_COH, REJ_ADR, REJ_CONT_B2G, REJ_REF_PJ, REJ_ASS_PJ (BR-FR-CDV-CL-09)",
                                  "tests": "ext 'fr-ctc-flow6-reason' in [MONTANTTOTAL_ERR, CALCUL_ERR, DOUBLON, ADR_ERR, REJ_SEMAN, REJ_UNI, REJ_COH, REJ_ADR, REJ_CONT_B2G, REJ_REF_PJ, REJ_ASS_PJ]"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "guard": "status type in [response]",
          "subsets": [
            {
              "field": "lines",
              "subsets": [
                {
                  "each": true,
                  "subsets": [
                    {
                      "field": "key",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-23",
                          "desc": "status line key must be consistent with status type 'response'",
                          "tests": "one of [acknowledged, processing, accepted, querying, rejected, error]"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "guard": "status type in [update]",
          "subsets": [
            {
              "field": "lines",
              "subsets": [
                {
                  "each": true,
                  "subsets": [
                    {
                      "field": "key",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-STATUS-24",
                          "desc": "status line key must be consistent with status type 'update'",
                          "tests": "one of [issued]"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT",
      "object": "bill.Payment",
      "subsets": [
        {
          "field": "type",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-01",
              "desc": "payment type must be 'advice' (CDAR 211) or 'receipt' (CDAR 212); 'request' is not a Flow 6 CDV event",
              "tests": "one of [advice, receipt]"
            }
          ]
        },
        {
          "field": "supplier",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-02",
              "desc": "payment supplier is required (BR-FR-CDV-13)",
              "tests": "present"
            }
          ],
          "subsets": [
            {
              "field": "identities",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-03",
                  "desc": "payment supplier must have an identity with ISO/IEC 6523 scheme 0002 (SIREN)",
                  "tests": "has a ext [iso-scheme-id] in [0002]"
                }
              ],
              "subsets": [
                {
                  "each": true,
                  "subsets": [
                    {
                      "field": "ext",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-04",
                          "desc": "payment supplier identity ext iso-scheme-id must be in the Flow 6 allow-list; STC 0231 is a Flow 2 invoice concept",
                          "tests": "ext 'iso-scheme-id' in [0002, 0009, 0223, 0224, 0226, 0227, 0228, 0229, 0238]"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "customer",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-05",
              "desc": "payment customer is required (BR-FR-CDV-CL-04)",
              "tests": "present"
            }
          ],
          "subsets": [
            {
              "field": "identities",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-06",
                  "desc": "payment customer must have an identity with ISO/IEC 6523 scheme 0002 (SIREN)",
                  "tests": "has a ext [iso-scheme-id] in [0002]"
                }
              ],
              "subsets": [
                {
                  "each": true,
                  "subsets": [
                    {
                      "field": "ext",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-07",
                          "desc": "payment customer identity ext iso-scheme-id must be in the Flow 6 allow-list; STC 0231 is a Flow 2 invoice concept",
                          "tests": "ext 'iso-scheme-id' in [0002, 0009, 0223, 0224, 0226, 0227, 0228, 0229, 0238]"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "payee",
          "subsets": [
            {
              "field": "identities",
              "subsets": [
                {
                  "each": true,
                  "subsets": [
                    {
                      "field": "ext",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-08",
                          "desc": "payment payee identity ext iso-scheme-id must be in the Flow 6 allow-list; STC 0231 is a Flow 2 invoice concept",
                          "tests": "ext 'iso-scheme-id' in [0002, 0009, 0223, 0224, 0226, 0227, 0228, 0229, 0238]"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "lines",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-09",
              "desc": "payment lines must contain exactly one entry (a CDV references a single invoice)",
              "tests": "exactly one line"
            }
          ],
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "field": "document",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-10",
                      "desc": "payment line document is required (BR-FR-CDV-10)",
                      "tests": "present"
                    }
                  ],
                  "subsets": [
                    {
                      "field": "code",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-11",
                          "desc": "payment line document code is required (BR-FR-CDV-10)",
                          "tests": "present"
                        }
                      ]
                    },
                    {
                      "field": "issue_date",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-12",
                          "desc": "payment line document issue_date is required (BR-FR-CDV-11)",
                          "tests": "present"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "ext",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-13",
              "desc": "payment ext fr-ctc-flow6-status must be a Payment-applicable ProcessConditionCode (211 advice or 212 receipt); codes 200-210, 213 belong on bill.Status",
              "tests": "ext 'fr-ctc-flow6-status' in [211, 212]"
            },
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-14",
              "desc": "payment ext fr-ctc-flow6-condition must be a Payment-applicable CharacteristicTypeCode (MEN, MPA, RAP); status-only codes (CBB, DIV, DVA, MAJ, MAP, MAPTTC, MNA, MNATTC, ESC, RAB, REM) belong on a bill.Reason under bill.Status",
              "tests": "ext 'fr-ctc-flow6-condition' in [MEN, MPA, RAP]"
            }
          ]
        },
        {
          "guard": "payment type in [advice]",
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-15",
                  "desc": "payment ext fr-ctc-flow6-status for an advice payment must be ProcessConditionCode 211 (Paiement transmis)",
                  "tests": "ext 'fr-ctc-flow6-status' in [211]"
                }
              ]
            }
          ]
        },
        {
          "guard": "payment type in [receipt]",
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW6-BILL-PAYMENT-16",
                  "desc": "payment ext fr-ctc-flow6-status for a receipt payment must be ProcessConditionCode 212 (Encaissée)",
                  "tests": "ext 'fr-ctc-flow6-status' in [212]"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-FR-CTC-FLOW6-BILL-REASON",
      "object": "bill.Reason",
      "subsets": [
        {
          "field": "ext",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-REASON-01",
              "desc": "reason ext fr-ctc-flow6-reason must be a known CDAR ReasonCode",
              "tests": "ext 'fr-ctc-flow6-reason' in [NON_TRANSMISE, JUSTIF_ABS, ROUTAGE_ERR, AUTRE, COORD_BANC_ERR, TX_TVA_ERR, MONTANTTOTAL_ERR, CALCUL_ERR, NON_CONFORME, DOUBLON, DEST_INC, DEST_ERR, TRANSAC_INC, EMMET_INC, CONTRAT_TERM, DOUBLE_FACT, CMD_ERR, ADR_ERR, SIRET_ERR, CODE_ROUTAGE_ERR, REF_CT_ABSENT, REF_ERR, PU_ERR, REM_ERR, QTE_ERR, ART_ERR, MODPAI_ERR, QUALITE_ERR, LIVR_INCOMP, REJ_SEMAN, REJ_UNI, REJ_COH, REJ_ADR, REJ_CONT_B2G, REJ_REF_PJ, REJ_ASS_PJ, IRR_VIDE_F, IRR_TYPE_F, IRR_SYNTAX, IRR_TAILLE_PJ, IRR_NOM_PJ, IRR_VID_PJ, IRR_EXT_DOC, IRR_TAILLE_F, IRR_ANTIVIRUS]"
            },
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-REASON-02",
              "desc": "reason ext fr-ctc-flow6-condition must be a Status-applicable CharacteristicTypeCode (CBB, DIV, DVA, MAJ, MAP, MAPTTC, MNA, MNATTC, ESC, RAB, REM); MEN, MPA, RAP belong on bill.Payment",
              "tests": "ext 'fr-ctc-flow6-condition' in [CBB, DIV, DVA, MAJ, MAP, MAPTTC, MNA, MNATTC, ESC, RAB, REM]"
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-FR-CTC-FLOW6-BILL-ACTION",
      "object": "bill.Action",
      "subsets": [
        {
          "field": "ext",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-BILL-ACTION-01",
              "desc": "action ext fr-ctc-flow6-action must be a known CDAR RequestedActionCode (MDT-121)",
              "tests": "ext 'fr-ctc-flow6-action' in [NOA, PIN, NIN, CNF, CNP, CNA, OTH]"
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-FR-CTC-FLOW6-ORG-PARTY",
      "object": "org.Party",
      "subsets": [
        {
          "field": "ext",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-ORG-PARTY-01",
              "desc": "party ext fr-ctc-flow6-role must be one of the UNCL 3035 subset: SE, BY, WK, DFH, AB, SR, DL, PE, PR, II, IV",
              "tests": "known fr-ctc-flow6-role"
            }
          ]
        },
        {
          "field": "identities",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW6-ORG-PARTY-02",
              "desc": "party identities SIRET and SIREN codes must be coherent (BR-FR-09/10)",
              "tests": "SIRET/SIREN coherent"
            },
            {
              "id": "GOBL-FR-CTC-FLOW6-ORG-PARTY-03",
              "desc": "party identities must not duplicate iso-scheme-id values (BR-FR-CO-10)",
              "tests": "unique iso-scheme-id"
            }
          ],
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "field": "ext",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW6-ORG-PARTY-04",
                      "desc": "party identity ext iso-scheme-id is required (BR-FR-CO-10)",
                      "tests": "ext require [iso-scheme-id]"
                    },
                    {
                      "id": "GOBL-FR-CTC-FLOW6-ORG-PARTY-05",
                      "desc": "party identity ext iso-scheme-id must be one of the Flow 6 allowed schemes (BR-FR-CO-10)",
                      "tests": "ext 'iso-scheme-id' in [0002, 0009, 0223, 0224, 0226, 0227, 0228, 0229, 0238]"
                    }
                  ]
                },
                {
