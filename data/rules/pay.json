{
  "id": "GOBL-PAY",
  "package": "pay",
  "subsets": [
    {
      "id": "GOBL-PAY-ADVANCE",
      "object": "pay.Advance",
      "subsets": [
        {
          "field": "description",
          "assert": [
            {
              "id": "GOBL-PAY-ADVANCE-01",
              "desc": "description is required",
              "tests": "present"
            }
          ]
        },
        {
          "field": "key",
          "subsets": [
            {
              "guard": "present",
              "assert": [
                {
                  "id": "GOBL-PAY-ADVANCE-02",
                  "desc": "key must be valid",
                  "tests": "be or starts with one of [any, card, card+credit, card+debit, credit-transfer, credit-transfer+sepa, debit-transfer, cash, cheque, bank-draft, direct-debit, direct-debit+sepa, online, promissory-note, netting, other]"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-PAY-INSTRUCTIONS",
      "object": "pay.Instructions",
      "subsets": [
        {
          "field": "key",
          "assert": [
            {
              "id": "GOBL-PAY-INSTRUCTIONS-01",
              "desc": "key is required",
              "tests": "present"
            }
          ],
          "subsets": [
            {
              "guard": "present",
              "assert": [
                {
                  "id": "GOBL-PAY-INSTRUCTIONS-02",
                  "desc": "key must be valid",
                  "tests": "be or starts with one of [any, card, card+credit, card+debit, credit-transfer, credit-transfer+sepa, debit-transfer, cash, cheque, bank-draft, direct-debit, direct-debit+sepa, online, promissory-note, netting, other]"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-PAY-ONLINE",
      "object": "pay.Online",
      "subsets": [
        {
          "field": "url",
          "assert": [
            {
              "id": "GOBL-PAY-ONLINE-01",
              "desc": "URL is required and must be valid",
              "tests": "present, url"
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-PAY-TERMS",
      "object": "pay.Terms",
      "subsets": [
        {
          "field": "key",
          "subsets": [
            {
              "guard": "present",
              "assert": [
                {
                  "id": "GOBL-PAY-TERMS-01",
                  "desc": "key must be valid",
                  "tests": "one of [end-of-month, due-date, deferred, proximo, instant, elective, pending, advanced, delivery, undefined]"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-PAY-DUEDATE",
      "object": "pay.DueDate",
      "subsets": [
        {
          "field": "date",
          "assert": [
            {
              "id": "GOBL-PAY-DUEDATE-01",
              "desc": "date is required",
              "tests": "present"
            }
          ]
        },
        {
          "field": "amount",
          "assert": [
            {
              "id": "GOBL-PAY-DUEDATE-02",
              "desc": "amount must not be zero",
              "tests": "not zero"
            }
          ]
        }
      ]
    }
  ]
}
