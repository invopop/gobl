{
  "id": "GOBL-ES-VERIFACTU-V1",
  "name": "es-verifactu-v1",
  "test": "has addon es-verifactu-v1",
  "subsets": [
    {
      "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE",
      "name": "bill.Invoice",
      "schema": "https://gobl.org/draft-0/bill/invoice",
      "subsets": [
        {
          "test": "corrective",
          "subsets": [
            {
              "field": "preceding",
              "assert": [
                {
                  "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-01",
                  "desc": "preceding documents are required for corrective invoices",
                  "tests": "required"
                }
              ]
            }
          ]
        },
        {
          "field": "preceding",
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "test": "not nil",
                  "subsets": [
                    {
                      "field": "issue_date",
                      "assert": [
                        {
                          "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-02",
                          "desc": "issue date is required",
                          "tests": "required"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "test": "corrective",
          "subsets": [
            {
              "field": "preceding",
              "subsets": [
                {
                  "each": true,
                  "subsets": [
                    {
                      "test": "not nil",
                      "subsets": [
                        {
                          "field": "tax",
                          "assert": [
                            {
                              "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-03",
                              "desc": "preceding invoice tax data is required for corrective invoices",
                              "tests": "required"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "test": "simplified",
          "subsets": [
            {
              "field": "customer",
              "assert": [
                {
                  "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-04",
                  "desc": "tax ID must not be set for simplified invoices",
                  "tests": "no tax_id"
                },
                {
                  "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-05",
                  "desc": "identity type extension not allowed for simplified invoices",
                  "tests": "no identity type ext"
                }
              ]
            }
          ]
        },
        {
          "test": "not simplified",
          "subsets": [
            {
              "field": "customer",
              "assert": [
                {
                  "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-06",
                  "desc": "customer is required",
                  "tests": "required"
                },
                {
                  "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-07",
                  "desc": "must have a tax_id or an identity with ext 'es-verifactu-v1-identity-type'",
                  "tests": "has tax_id or identity"
                },
                {
                  "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-08",
                  "desc": "tax ID must have a code",
                  "tests": "tax_id has code"
                }
              ]
            }
          ]
        },
        {
          "field": "tax",
          "assert": [
            {
              "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-09",
              "desc": "tax is required",
              "tests": "required"
            }
          ],
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-10",
                  "desc": "doc type is required",
                  "tests": "has doc type"
                }
              ],
              "subsets": [
                {
                  "test": "credit/debit doc type",
                  "assert": [
                    {
                      "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-13",
                      "desc": "correction type is required",
                      "tests": "has correction type"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "test": "standard invoice type",
          "subsets": [
            {
              "field": "tax",
              "subsets": [
                {
                  "field": "ext",
                  "assert": [
                    {
                      "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-11",
                      "desc": "doc type for standard invoices must be F1, F2, or F3",
                      "tests": "standard doc type"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "test": "corrective invoice type",
          "subsets": [
            {
              "field": "tax",
              "subsets": [
                {
                  "field": "ext",
                  "assert": [
                    {
                      "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-12",
                      "desc": "doc type for corrective invoices must be R1, R2, R3, R4, or R5",
                      "tests": "corrective doc type"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "notes",
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "test": "general note",
                  "subsets": [
                    {
                      "field": "text",
                      "assert": [
                        {
                          "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-14",
                          "desc": "general note text must be 500 characters or less",
                          "tests": "length between 0 and 500"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "lines",
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "field": "taxes",
                  "assert": [
                    {
                      "id": "GOBL-ES-VERIFACTU-V1-BILL-INVOICE-15",
                      "desc": "must include at least one of VAT, IGIC, or IPSI",
                      "tests": "has required tax category"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-ES-VERIFACTU-V1-TAX-COMBO",
      "name": "tax.Combo",
      "subsets": [
        {
          "test": "verifactu vat/igic",
          "assert": [
            {
              "id": "GOBL-ES-VERIFACTU-V1-TAX-COMBO-10",
              "desc": "cannot use both op_class and exempt at the same time",
              "tests": "not both op_class and exempt"
            }
          ],
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-ES-VERIFACTU-V1-TAX-COMBO-01",
                  "desc": "regime is required",
                  "tests": "has regime"
                }
              ]
            },
            {
              "test": "has percent",
              "subsets": [
                {
                  "field": "ext",
                  "assert": [
                    {
                      "id": "GOBL-ES-VERIFACTU-V1-TAX-COMBO-02",
                      "desc": "op_class is required for taxed operations",
                      "tests": "has op_class"
                    }
                  ]
                }
              ]
            },
            {
              "test": "regime 01",
              "subsets": [
                {
                  "field": "ext",
                  "assert": [
                    {
                      "id": "GOBL-ES-VERIFACTU-V1-TAX-COMBO-11",
                      "desc": "exempt codes E2 and E3 not allowed with regime 01",
                      "tests": "no E2/E3"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
