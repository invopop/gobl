{
  "id": "GOBL-FR-CTC-FLOW2",
  "package": "fr-ctc-flow2",
  "guard": "context: addon in [fr-ctc-flow2-v1]",
  "subsets": [
    {
      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE",
      "object": "bill.Invoice",
      "assert": [
        {
          "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-01",
          "desc": "invoice must be in EUR or provide an exchange rate to EUR",
          "tests": "can convert to [EUR]"
        },
        {
          "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-02",
          "desc": "invoice code (with series, when set) must be 1-35 characters of alphanumerics plus -+_/ (BR-FR-01/02)",
          "tests": "valid invoice code"
        }
      ],
      "subsets": [
        {
          "field": "preceding",
          "subsets": [
            {
              "each": true,
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-03",
                  "desc": "invoice preceding code (with series, when set) must be 1-35 characters of alphanumerics plus -+_/ (BR-FR-01/02)",
                  "tests": "valid preceding code"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice tax ext untdid-document-type in [384, 471, 472, 473]",
          "subsets": [
            {
              "field": "preceding",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-04",
                  "desc": "invoice preceding is required for corrective invoices (BR-FR-CO-04)",
                  "tests": "present"
                },
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-05",
                  "desc": "invoice preceding must contain exactly one reference for corrective invoices (BR-FR-CO-04)",
                  "tests": "length between 1 and 1"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice tax ext untdid-document-type in [261, 381, 396, 502, 503]",
          "subsets": [
            {
              "field": "preceding",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-06",
                  "desc": "invoice preceding must contain at least one reference for credit notes (BR-FR-CO-05)",
                  "tests": "present"
                }
              ]
            }
          ]
        },
        {
          "field": "tax",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-07",
              "desc": "invoice tax is required",
              "tests": "present"
            }
          ],
          "subsets": [
            {
              "field": "ext",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-08",
                  "desc": "invoice tax ext untdid-document-type must be a valid Flow 2 document type (BR-FR-04)",
                  "tests": "ext 'untdid-document-type' in [380, 389, 393, 501, 386, 500, 384, 471, 472, 473, 381, 261, 396, 502, 503, 262]"
                },
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-09",
                  "desc": "invoice tax ext dgfip-billing-mode is required",
                  "tests": "ext require [dgfip-billing-mode]"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice tax ext dgfip-billing-mode in [B4, S4, M4]",
          "subsets": [
            {
              "field": "tax",
              "subsets": [
                {
                  "field": "ext",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-10",
                      "desc": "invoice tax ext untdid-document-type must not be an advance-payment code (386, 500, 503) when billing mode is factoring (B4, S4, M4) (BR-FR-CO-08)",
                      "tests": "ext 'untdid-document-type' not in [386, 500, 503]"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "supplier",
          "subsets": [
            {
              "field": "inboxes",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-11",
                  "desc": "invoice supplier inboxes are required for French B2B invoices (BR-FR-13)",
                  "tests": "present"
                }
              ]
            },
            {
              "field": "identities",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-12",
                  "desc": "invoice supplier identities must include a SIREN identity with iso-scheme-id 0002 and scope legal (BR-FR-10/11)",
                  "tests": "has SIREN (legal scope)"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice tax ext untdid-document-type not in [389, 501, 500, 471, 473, 261, 502]",
          "subsets": [
            {
              "field": "supplier",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-13",
                  "desc": "invoice supplier must have an inbox with scheme 0225 matching the SIREN code (BR-FR-21/22)",
                  "tests": "has SIREN inbox"
                }
              ]
            }
          ]
        },
        {
          "field": "customer",
          "subsets": [
            {
              "field": "inboxes",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-14",
                  "desc": "invoice customer inboxes are required for French B2B invoices (BR-FR-13)",
                  "tests": "present"
                }
              ]
            },
            {
              "field": "identities",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-15",
                  "desc": "invoice customer identities must include a SIREN identity with iso-scheme-id 0002 and scope legal (BR-FR-10/11)",
                  "tests": "has SIREN (legal scope)"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice tax ext untdid-document-type in [389, 501, 500, 471, 473, 261, 502]",
          "subsets": [
            {
              "field": "customer",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-16",
                  "desc": "invoice customer must have an inbox with scheme 0225 matching the SIREN code (BR-FR-21/22)",
                  "tests": "has SIREN inbox"
                }
              ]
            }
          ]
        },
        {
          "field": "ordering",
          "subsets": [
            {
              "field": "identities",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-17",
                  "desc": "invoice ordering identities must not contain more than one entry with UNTDID reference 'AFL' (BR-FR-30)",
                  "tests": "identities have at most one ext untdid-reference=AFL"
                },
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-18",
                  "desc": "invoice ordering identities must not contain more than one entry with UNTDID reference 'AWW' (BR-FR-30)",
                  "tests": "identities have at most one ext untdid-reference=AWW"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice supplier is under STC scheme",
          "subsets": [
            {
              "field": "ordering",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-19",
                  "desc": "invoice ordering is required when supplier is under STC scheme (BR-FR-CO-15)",
                  "tests": "present"
                }
              ],
              "subsets": [
                {
                  "field": "seller",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-20",
                      "desc": "invoice ordering seller is required when supplier is under STC scheme (BR-FR-CO-15)",
                      "tests": "present"
                    }
                  ],
                  "subsets": [
                    {
                      "field": "tax_id",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-21",
                          "desc": "invoice ordering seller tax_id is required when supplier is under STC scheme (BR-FR-CO-15)",
                          "tests": "present"
                        }
                      ],
                      "subsets": [
                        {
                          "field": "code",
                          "assert": [
                            {
                              "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-22",
                              "desc": "invoice ordering seller tax_id code is required when supplier is under STC scheme (BR-FR-CO-15)",
                              "tests": "present"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "field": "notes",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-23",
                  "desc": "invoice notes must include an entry with subject TXD and text MEMBRE_ASSUJETTI_UNIQUE when supplier is under STC scheme (BR-FR-CO-14)",
                  "tests": "has TXD note"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice tax ext untdid-document-type in [262]",
          "subsets": [
            {
              "field": "ordering",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-24",
                  "desc": "invoice ordering is required for consolidated credit notes (BR-FR-CO-03)",
                  "tests": "present"
                }
              ],
              "subsets": [
                {
                  "field": "contracts",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-25",
                      "desc": "invoice ordering contracts is required for consolidated credit notes (BR-FR-CO-03)",
                      "tests": "present"
                    },
                    {
                      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-26",
                      "desc": "invoice ordering contracts must contain at least one entry for consolidated credit notes (BR-FR-CO-03)",
                      "tests": "length between 1 and 0"
                    }
                  ]
                }
              ]
            },
            {
              "field": "delivery",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-27",
                  "desc": "invoice delivery is required for consolidated credit notes (BR-FR-CO-03)",
                  "tests": "present"
                }
              ],
              "subsets": [
                {
                  "field": "period",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-28",
                      "desc": "invoice delivery period is required for consolidated credit notes (BR-FR-CO-03)",
                      "tests": "present"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice tax ext untdid-document-type not in [386, 500, 503]",
          "subsets": [
            {
              "guard": "invoice tax ext dgfip-billing-mode not in [B2, S2, M2]",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-29",
                  "desc": "invoice payment terms due_dates must not be before the invoice issue date (BR-FR-CO-07)",
                  "tests": "due dates valid"
                }
              ]
            }
          ]
        },
        {
          "guard": "invoice tax ext dgfip-billing-mode in [B2, S2, M2]",
          "subsets": [
            {
              "field": "payment",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-30",
                  "desc": "invoice payment is required for final invoices (BR-FR-CO-09)",
                  "tests": "present"
                }
              ],
              "subsets": [
                {
                  "field": "terms",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-31",
                      "desc": "invoice payment terms is required for final invoices (BR-FR-CO-09)",
                      "tests": "present"
                    }
                  ],
                  "subsets": [
                    {
                      "field": "due_dates",
                      "assert": [
                        {
                          "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-32",
                          "desc": "invoice payment terms due_dates must contain at least one entry for final invoices (BR-FR-CO-09)",
                          "tests": "present"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "field": "totals",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-34",
                  "desc": "invoice totals advance must equal total_with_tax for final invoices (BR-FR-CO-09)",
                  "tests": "advances match total_with_tax"
                },
                {
                  "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-35",
                  "desc": "invoice totals payable must be zero for final invoices (BR-FR-CO-09)",
                  "tests": "payable is zero"
                }
              ],
              "subsets": [
                {
                  "field": "advance",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-33",
                      "desc": "invoice totals advance is required for final invoices (BR-FR-CO-09)",
                      "tests": "present"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "notes",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-36",
              "desc": "invoice notes are required for French CTC invoices (BR-FR-05)",
              "tests": "present"
            },
            {
              "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-37",
              "desc": "invoice notes must include entries with subjects PMT, PMD and AAB (BR-FR-05)",
              "tests": "has required note subjects"
            },
            {
              "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-38",
              "desc": "invoice notes must not contain duplicate subjects PMT, PMD, AAB or TXD (BR-FR-06/BR-FR-30)",
              "tests": "no duplicate note subjects"
            }
          ]
        },
        {
          "field": "attachments",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-41",
              "desc": "invoice attachments must not contain more than one entry with description 'LISIBLE' (BR-FR-18)",
              "tests": "at most one LISIBLE"
            }
          ],
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "field": "description",
                  "assert": [
                    {
                      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-39",
                      "desc": "invoice attachment description is required (BR-FR-17)",
                      "tests": "present"
                    },
                    {
                      "id": "GOBL-FR-CTC-FLOW2-BILL-INVOICE-40",
                      "desc": "invoice attachment description must be one of the allowed values (BR-FR-17)",
                      "tests": "one of [RIB, LISIBLE, FEUILLE_DE_STYLE, PJA, BON_LIVRAISON, BON_COMMANDE, DOCUMENT_ANNEXE, BORDEREAU_SUIVI, BORDEREAU_SUIVI_VALIDATION, ETAT_ACOMPTE, FACTURE_PAIEMENT_DIRECT, RECAPITULATIF_COTRAITANCE]"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-FR-CTC-FLOW2-ORG-PARTY",
      "object": "org.Party",
      "subsets": [
        {
          "field": "identities",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW2-ORG-PARTY-01",
              "desc": "SIRET and SIREN must be coherent (BR-FR-09/10)",
              "tests": "SIRET/SIREN coherent"
            },
            {
              "id": "GOBL-FR-CTC-FLOW2-ORG-PARTY-02",
              "desc": "identity scheme format invalid (BR-FR-CO-10)",
              "tests": "valid scheme format"
            }
          ]
        },
        {
          "field": "inboxes",
          "subsets": [
            {
              "each": true,
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-ORG-PARTY-03",
                  "desc": "inbox code format invalid",
                  "tests": "valid inbox"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-FR-CTC-FLOW2-ORG-IDENTITY",
      "object": "org.Identity",
      "subsets": [
        {
          "guard": "scheme 0224",
          "subsets": [
            {
              "field": "code",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-ORG-IDENTITY-01",
                  "desc": "must be no more than 100 characters long",
                  "tests": "length between 0 and 100"
                },
                {
                  "id": "GOBL-FR-CTC-FLOW2-ORG-IDENTITY-02",
                  "desc": "must be in a valid format",
                  "tests": "matches ^[A-Za-z0-9\\-\\+_/]+$"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-FR-CTC-FLOW2-ORG-INBOX",
      "object": "org.Inbox",
      "subsets": [
        {
          "guard": "scheme 0225",
          "subsets": [
            {
              "field": "code",
              "assert": [
                {
                  "id": "GOBL-FR-CTC-FLOW2-ORG-INBOX-01",
                  "desc": "the length must be between 0 and 125",
                  "tests": "length between 0 and 125"
                },
                {
                  "id": "GOBL-FR-CTC-FLOW2-ORG-INBOX-02",
                  "desc": "must be in a valid format",
                  "tests": "matches ^[A-Za-z0-9\\-\\+_/]+$"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-FR-CTC-FLOW2-ORG-ITEM",
      "object": "org.Item",
      "subsets": [
        {
          "field": "meta",
          "assert": [
            {
              "id": "GOBL-FR-CTC-FLOW2-ORG-ITEM-01",
              "desc": "meta values cannot be blank (BR-FR-28)",
              "tests": "no blank meta"
            }
          ]
        }
      ]
    }
  ]
}
