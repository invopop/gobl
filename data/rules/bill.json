        },
        {
          "field": "issue_date",
          "assert": [
            {
              "id": "GOBL-BILL-ORDER-03",
              "desc": "issue date is required",
              "tests": "present"
            }
          ]
        },
        {
          "field": "currency",
          "assert": [
            {
              "id": "GOBL-BILL-ORDER-04",
              "desc": "currency is required",
              "tests": "present"
            }
          ]
        },
        {
          "field": "supplier",
          "assert": [
            {
              "id": "GOBL-BILL-ORDER-05",
              "desc": "supplier is required",
              "tests": "present"
            }
          ]
        },
        {
          "field": "lines",
          "assert": [
            {
              "id": "GOBL-BILL-ORDER-06",
              "desc": "lines are required",
              "tests": "present"
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BILL-PAYMENT",
      "name": "bill.Payment",
      "subsets": [
        {
          "field": "type",
          "assert": [
            {
              "id": "GOBL-BILL-PAYMENT-01",
              "desc": "payment type is required",
              "tests": "present"
            },
            {
              "id": "GOBL-BILL-PAYMENT-02",
              "desc": "payment type is not valid",
              "tests": "one of [request, advice, receipt]"
