    {
      "id": "GOBL-BILL-LINEDISCOUNT",
      "name": "bill.LineDiscount",
      "subsets": [
        {
          "guard": "Base != nil",
          "subsets": [
            {
              "field": "percent",
              "assert": [
                {
                  "id": "GOBL-BILL-LINEDISCOUNT-01",
                  "desc": "percent is required when base is set",
                  "tests": "present"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BILL-LINECHARGE",
      "name": "bill.LineCharge",
      "subsets": [
        {
          "guard": "Base != nil",
          "subsets": [
            {
              "field": "percent",
              "assert": [
                {
                  "id": "GOBL-BILL-LINECHARGE-01",
                  "desc": "percent is required when base is set",
                  "tests": "present"
                }
              ]
            }
          ]
        },
        {
          "guard": "Base != nil || Percent != nil",
          "subsets": [
            {
              "field": "quantity",
              "assert": [
                {
                  "id": "GOBL-BILL-LINECHARGE-02",
                  "desc": "quantity must be blank with base or percent",
                  "tests": "empty"
                }
              ]
            },
            {
              "field": "rate",
              "assert": [
                {
                  "id": "GOBL-BILL-LINECHARGE-03",
                  "desc": "rate must be blank with base or percent",
                  "tests": "empty"
                }
              ]
            }
          ]
        },
        {
          "guard": "Quantity == nil",
          "subsets": [
            {
              "field": "unit",
              "assert": [
                {
                  "id": "GOBL-BILL-LINECHARGE-04",
                  "desc": "unit must be blank without quantity",
                  "tests": "empty"
                }
              ]
            }
          ]
        },
        {
          "guard": "Quantity != nil",
          "subsets": [
            {
              "field": "rate",
              "assert": [
                {
                  "id": "GOBL-BILL-LINECHARGE-05",
                  "desc": "rate is required when quantity is set",
                  "tests": "present"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BILL-DISCOUNT",
      "name": "bill.Discount",
      "subsets": [
        {
          "guard": "Base != nil",
          "subsets": [
            {
              "field": "percent",
              "assert": [
                {
                  "id": "GOBL-BILL-DISCOUNT-01",
                  "desc": "percent is required when base is set",
                  "tests": "present"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BILL-CHARGE",
      "name": "bill.Charge",
      "subsets": [
        {
          "guard": "Base != nil",
          "subsets": [
            {
              "field": "percent",
              "assert": [
                {
                  "id": "GOBL-BILL-CHARGE-01",
                  "desc": "percent is required when base is set",
                  "tests": "present"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BILL-PAYMENTLINE",
      "name": "bill.PaymentLine",
      "assert": [
        {
          "id": "GOBL-BILL-PAYMENTLINE-11",
          "desc": "advances must not exceed payable",
          "tests": "advances within payable"
        },
        {
          "id": "GOBL-BILL-PAYMENTLINE-12",
          "desc": "amount must not exceed payable less advances",
          "tests": "amount within limit"
        }
      ],
      "subsets": [
        {
          "field": "installment",
          "assert": [
            {
              "id": "GOBL-BILL-PAYMENTLINE-01",
              "desc": "installment must be between 1 and 999",
              "tests": "at least 1, at most 999"
            }
          ]
        },
        {
          "field": "payable",
          "assert": [
            {
              "id": "GOBL-BILL-PAYMENTLINE-02",
              "desc": "payable must be positive",
              "tests": "min 0"
            }
          ]
        },
        {
          "field": "advances",
          "assert": [
            {
              "id": "GOBL-BILL-PAYMENTLINE-03",
              "desc": "advances must be zero or positive",
              "tests": "min 0"
            }
          ]
        },
        {
          "field": "amount",
          "assert": [
            {
              "id": "GOBL-BILL-PAYMENTLINE-04",
              "desc": "amount must be positive",
              "tests": "min 0"
            }
          ]
        },
        {
          "field": "due",
          "assert": [
            {
              "id": "GOBL-BILL-PAYMENTLINE-05",
              "desc": "due must be zero or positive",
              "tests": "min 0"
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BILL-TAX",
      "name": "bill.Tax",
      "subsets": [
        {
          "field": "rounding",
          "subsets": [
            {
              "guard": "present",
              "assert": [
                {
                  "id": "GOBL-BILL-TAX-01",
                  "desc": "rounding model is not valid",
                  "tests": "one of [precise, currency]"
                }
              ]
            }
          ]
        },
        {
          "field": "point",
          "subsets": [
            {
              "guard": "present",
              "assert": [
                {
                  "id": "GOBL-BILL-TAX-02",
                  "desc": "tax point is not valid",
                  "tests": "one of [issue, delivery, payment]"
                }
              ]
            }
          ]
        }
      ]
    },
    {
