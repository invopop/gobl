              "id": "GOBL-BILL-LINE-03",
              "desc": "item is required",
              "tests": "present"
            }
          ]
        },
        {
          "guard": "item has price",
          "subsets": [
            {
              "field": "sum",
              "assert": [
                {
                  "id": "GOBL-BILL-LINE-04",
                  "desc": "sum is required when item has a price",
                  "tests": "present"
                }
              ]
            },
            {
              "field": "total",
              "assert": [
