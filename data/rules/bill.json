{
  "id": "GOBL-BILL",
  "name": "bill",
  "subsets": [
    {
      "id": "GOBL-BILL-INVOICE",
      "name": "bill.Invoice",
      "subsets": [
        {
          "field": "type",
          "assert": [
            {
              "id": "GOBL-BILL-INVOICE-01",
              "desc": "invoice type is required",
              "tests": "present"
            },
            {
              "id": "GOBL-BILL-INVOICE-02",
              "desc": "invoice type is not valid",
              "tests": "one of [standard, proforma, corrective, credit-note, debit-note, other]"
            }
          ]
        },
        {
          "field": "issue_date",
          "assert": [
            {
              "id": "GOBL-BILL-INVOICE-03",
              "desc": "invoice issue date is required",
              "tests": "not zero"
            }
          ]
        },
        {
          "field": "currency",
          "assert": [
            {
              "id": "GOBL-BILL-INVOICE-04",
              "desc": "invoice currency is required",
              "tests": "present"
            }
          ]
        },
        {
          "field": "supplier",
          "assert": [
            {
              "id": "GOBL-BILL-INVOICE-05",
              "desc": "invoice supplier is required",
              "tests": "present"
            }
          ],
          "subsets": [
            {
              "field": "name",
              "assert": [
                {
                  "id": "GOBL-BILL-INVOICE-06",
                  "desc": "invoice supplier name is required",
                  "tests": "present"
                }
              ]
            }
          ]
        },
        {
          "guard": "has tax point",
          "subsets": [
            {
              "field": "value_date",
              "assert": [
                {
                  "id": "GOBL-BILL-INVOICE-11",
                  "desc": "value date cannot be set when tax point is set",
                  "tests": "empty"
                }
              ]
            }
          ]
        },
        {
          "field": "customer",
          "subsets": [
            {
              "guard": "has tax ID code",
              "subsets": [
                {
                  "field": "name",
                  "assert": [
                    {
                      "id": "GOBL-BILL-INVOICE-07",
                      "desc": "invoice customer name required when tax ID is set",
                      "tests": "present"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "lines",
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "field": "item",
                  "subsets": [
                    {
                      "field": "price",
                      "assert": [
                        {
                          "id": "GOBL-BILL-INVOICE-08",
                          "desc": "invoice line item price is required",
                          "tests": "present"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "totals",
          "assert": [
            {
              "id": "GOBL-BILL-INVOICE-09",
              "desc": "invoice totals are required",
              "tests": "present"
            }
          ]
        },
        {
          "guard": "no discounts or charges",
          "subsets": [
            {
              "field": "lines",
              "assert": [
                {
                  "id": "GOBL-BILL-INVOICE-10",
                  "desc": "invoice lines are required without discounts or charges",
                  "tests": "present"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BILL-DELIVERY",
      "name": "bill.Delivery",
      "subsets": [
        {
          "field": "type",
          "assert": [
            {
              "id": "GOBL-BILL-DELIVERY-01",
              "desc": "type is required",
              "tests": "present"
            },
            {
              "id": "GOBL-BILL-DELIVERY-02",
