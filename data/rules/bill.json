              "tests": "present"
            }
          ]
        },
        {
          "field": "lines",
          "assert": [
            {
              "id": "GOBL-BILL-DELIVERY-05",
              "desc": "lines are required",
              "tests": "present"
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BILL-ORDER",
      "name": "bill.Order",
      "subsets": [
        {
          "field": "type",
          "assert": [
            {
              "id": "GOBL-BILL-ORDER-01",
              "desc": "type is required",
