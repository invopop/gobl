            }
          ]
        },
        {
          "field": "lines",
          "assert": [
            {
              "id": "GOBL-BILL-PAYMENT-07",
              "desc": "payment lines are required",
              "tests": "present"
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-BILL-LINE",
      "name": "bill.Line",
      "subsets": [
        {
          "field": "i",
          "assert": [
            {
              "id": "GOBL-BILL-LINE-01",
              "desc": "index is required",
              "tests": "present"
            }
          ]
        },
        {
          "field": "quantity",
          "assert": [
            {
              "id": "GOBL-BILL-LINE-02",
              "desc": "quantity is required",
              "tests": "present"
            }
          ]
        },
        {
          "field": "item",
          "assert": [
