  "package": "peppol-bis-v3",
  "guard": "context: addon in [peppol-bis-v3]",
  "subsets": [
    {
      "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE",
      "object": "bill.Invoice",
      "assert": [
        {
          "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-R003",
          "desc": "buyer reference or purchase order reference is required (PEPPOL-EN16931-R003)",
          "tests": "buyer reference"
        },
        {
          "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-P0100",
          "desc": "invoice type code must be one of 380, 383, 386, 389, 751 (PEPPOL-EN16931-P0100)",
          "tests": "invoice type code"
        },
        {
          "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-P0101",
          "desc": "credit note type code must be one of 381, 396, 261 (PEPPOL-EN16931-P0101)",
          "tests": "credit note type code"
        },
        {
          "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-P0112",
          "desc": "invoice type 326 or 384 only allowed when both buyer and seller are Italian (PEPPOL-EN16931-P0112)",
          "tests": "partial/corrective IT-only"
        }
      ],
      "subsets": [
        {
          "field": "notes",
          "assert": [
            {
              "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-R002",
              "desc": "at most one note allowed unless both buyer and seller are Danish (PEPPOL-EN16931-R002)",
              "tests": "notes cardinality"
            }
          ]
        },
        {
          "field": "ordering",
          "subsets": [
            {
              "field": "projects",
              "assert": [
                {
                  "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-R080",
                  "desc": "only one project reference allowed (PEPPOL-EN16931-R080)",
                  "tests": "length between 0 and 1"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE",
      "object": "bill.Invoice",
      "assert": [
        {
          "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-R110",
          "desc": "line period start must be within invoice period (PEPPOL-EN16931-R110)",
          "tests": "line period start"
        },
        {
          "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-R111",
          "desc": "line period end must be within invoice period (PEPPOL-EN16931-R111)",
          "tests": "line period end"
        }
      ]
    },
    {
      "id": "GOBL-PEPPOL-BIS-V3-PAY-INSTRUCTIONS",
      "object": "pay.Instructions",
      "assert": [
        {
          "id": "GOBL-PEPPOL-BIS-V3-PAY-INSTRUCTIONS-R061",
          "desc": "mandate reference is required for direct debit payments (PEPPOL-EN16931-R061)",
          "tests": "direct debit mandate"
        }
