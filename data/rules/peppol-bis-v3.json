                    {
                      "each": true,
                      "assert": [
                        {
                          "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-DK-R-013",
                          "desc": "Danish supplier identities must specify an ISO 6523 scheme ID (DK-R-013)",
                          "tests": "identity has scheme"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "field": "customer",
              "subsets": [
                {
                  "guard": "customer is DK",
                  "assert": [
                    {
                      "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-DK-R-017",
                      "desc": "Danish customer should provide a CVR identity with scheme 0184 (DK-R-017)",
                      "tests": "dk customer cvr"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE",
