    {
      "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE",
      "object": "bill.Invoice",
      "subsets": [
        {
          "guard": "supplier country DK",
          "subsets": [
            {
              "field": "supplier",
              "assert": [
                {
                  "id": "GOBL-PEPPOL-BIS-V3-BILL-INVOICE-DK-R-002",
                  "desc": "Danish supplier must provide a CVR identity with scheme 0184 (DK-R-002, DK-R-014)",
                  "tests": "dk supplier cvr"
                }
              ],
              "subsets": [
                {
                  "field": "identities",
