{
  "id": "GOBL-NO",
  "package": "no",
  "subsets": [
    {
      "id": "GOBL-NO-TAX-IDENTITY",
      "object": "tax.Identity",
      "subsets": [
        {
          "guard": "code in [NO]",
          "subsets": [
            {
              "field": "code",
              "subsets": [
                {
                  "guard": "present",
                  "assert": [
                    {
                      "id": "GOBL-NO-TAX-IDENTITY-01",
                      "desc": "invalid Norwegian VAT number",
                      "tests": "valid MVA-suffixed mod-11 org number"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-NO-ORG-IDENTITY",
      "object": "org.Identity",
      "subsets": [
        {
          "guard": "context: regime in [NO]",
          "subsets": [
            {
              "guard": "type in [ON]",
              "subsets": [
                {
                  "field": "code",
                  "assert": [
                    {
                      "id": "GOBL-NO-ORG-IDENTITY-01",
                      "desc": "invalid organisasjonsnummer",
                      "tests": "valid mod-11 org number"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
