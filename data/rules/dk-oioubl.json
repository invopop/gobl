{
  "id": "GOBL-DK-OIOUBL",
  "package": "dk-oioubl",
  "guard": "context: addon in [dk-oioubl-v2-1]",
  "subsets": [
    {
      "id": "GOBL-DK-OIOUBL-BILL-INVOICE",
      "object": "bill.Invoice",
      "subsets": [
        {
          "field": "code",
          "assert": [
            {
              "id": "GOBL-DK-OIOUBL-BILL-INVOICE-05",
              "desc": "invoice code is required (F-INV009 / F-CRN006)",
              "tests": "present"
            }
          ]
        },
        {
          "field": "supplier",
          "subsets": [
            {
              "field": "inboxes",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-INVOICE-01",
                  "desc": "supplier inboxes are required (F-INV031 / F-CRN028)",
                  "tests": "present"
                }
              ]
            },
            {
              "field": "addresses",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-INVOICE-16",
                  "desc": "supplier address requires a street number or PO box (F-LIB035)",
                  "tests": "first address has a number or PO box"
                }
              ]
            }
          ]
        },
        {
          "field": "customer",
          "subsets": [
            {
              "field": "inboxes",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-INVOICE-02",
                  "desc": "customer inboxes are required (F-INV044 / F-CRN040)",
                  "tests": "present"
                }
              ]
            },
            {
              "field": "people",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-INVOICE-03",
                  "desc": "customer people are required (F-INV046 / F-CRN042)",
                  "tests": "present"
                }
              ]
            },
            {
              "field": "addresses",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-INVOICE-17",
                  "desc": "customer address requires a street number or PO box (F-LIB035)",
                  "tests": "first address has a number or PO box"
                }
              ]
            }
          ]
        },
        {
          "guard": "non-credit-note invoice with line order ref",
          "subsets": [
            {
              "field": "ordering",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-INVOICE-07",
                  "desc": "ordering is required when any invoice line has an order reference (F-INV142)",
                  "tests": "present"
                }
              ]
            }
          ]
        },
        {
          "field": "totals",
          "subsets": [
            {
              "field": "rounding",
              "subsets": [
                {
                  "guard": "present",
                  "assert": [
                    {
                      "id": "GOBL-DK-OIOUBL-BILL-INVOICE-08",
                      "desc": "rounding must be between -10.00 and 10.00 (F-INV338 / F-CRN208)",
                      "tests": "in rounding range"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "delivery",
          "subsets": [
            {
              "guard": "receiver set without identities or addresses",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-INVOICE-11",
                  "desc": "delivery requires either identities or receiver.addresses (F-INV239 / F-CRN158)",
                  "tests": "never"
                }
              ]
            }
          ]
        },
        {
          "field": "payment",
          "subsets": [
            {
              "field": "instructions",
              "subsets": [
                {
                  "field": "ext",
                  "subsets": [
                    {
                      "guard": "present",
                      "assert": [
                        {
                          "id": "GOBL-DK-OIOUBL-BILL-INVOICE-12",
                          "desc": "payment-means code must be one of the OIOUBL allowed values (F-LIB100)",
                          "tests": "ext 'untdid-payment-means' in [1, 10, 20, 30, 31, 42, 48, 49, 50, 58, 59, 93, 97]"
                        }
                      ]
                    }
                  ]
                },
                {
                  "guard": "bank-transfer payment means without a payee account",
                  "assert": [
                    {
                      "id": "GOBL-DK-OIOUBL-BILL-INVOICE-13",
                      "desc": "a credit transfer account (IBAN or number) is required for bank-transfer payment means (F-LIB107 / F-LIB126)",
                      "tests": "never"
                    }
                  ]
                },
                {
                  "guard": "giro payment means without a valid OIOUBL payment id",
                  "assert": [
                    {
                      "id": "GOBL-DK-OIOUBL-BILL-INVOICE-14",
                      "desc": "Giro (payment-means 50) requires a dk-oioubl-payment-id of 01, 04 or 15 (F-LIB144 / F-LIB147)",
                      "tests": "never"
                    }
                  ]
                },
                {
                  "guard": "fik payment means without a valid OIOUBL payment id",
                  "assert": [
                    {
                      "id": "GOBL-DK-OIOUBL-BILL-INVOICE-15",
                      "desc": "FIK (payment-means 93) requires a dk-oioubl-payment-id of 71, 73 or 75 (F-LIB152)",
                      "tests": "never"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "field": "lines",
          "subsets": [
            {
              "each": true,
              "subsets": [
                {
                  "field": "quantity",
                  "assert": [
                    {
                      "id": "GOBL-DK-OIOUBL-BILL-INVOICE-06",
                      "desc": "line quantity must not be zero (F-INV147 / F-CRN088)",
                      "tests": "non-zero amount"
                    }
                  ]
                },
                {
                  "field": "discounts",
                  "subsets": [
                    {
                      "each": true,
                      "subsets": [
                        {
                          "field": "amount",
                          "assert": [
                            {
                              "id": "GOBL-DK-OIOUBL-BILL-INVOICE-09",
                              "desc": "line discount amount must not be negative (F-INV335 / F-CRN203)",
                              "tests": "non-negative amount"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "field": "charges",
                  "subsets": [
                    {
                      "each": true,
                      "subsets": [
                        {
                          "field": "amount",
                          "assert": [
                            {
                              "id": "GOBL-DK-OIOUBL-BILL-INVOICE-10",
                              "desc": "line charge amount must not be negative (F-INV335 / F-CRN203)",
                              "tests": "non-negative amount"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GOBL-DK-OIOUBL-BILL-STATUS",
      "object": "bill.Status",
      "subsets": [
        {
          "guard": "response status type",
          "subsets": [
            {
              "field": "code",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-STATUS-05",
                  "desc": "code is required (F-APR005)",
                  "tests": "present"
                }
              ]
            },
            {
              "field": "supplier",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-STATUS-06",
                  "desc": "supplier must have a tax ID or identities (F-APR040)",
                  "tests": "has tax id or identities"
                },
                {
                  "id": "GOBL-DK-OIOUBL-BILL-STATUS-07",
                  "desc": "supplier must have a name or identities (F-LIB022)",
                  "tests": "has name or identities"
                }
              ],
              "subsets": [
                {
                  "field": "inboxes",
                  "assert": [
                    {
                      "id": "GOBL-DK-OIOUBL-BILL-STATUS-01",
                      "desc": "supplier inboxes are required (F-APR008)",
                      "tests": "present"
                    }
                  ]
                }
              ]
            },
            {
              "field": "customer",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-STATUS-02",
                  "desc": "customer is required for a response",
                  "tests": "present"
                },
                {
                  "id": "GOBL-DK-OIOUBL-BILL-STATUS-08",
                  "desc": "customer must have a name or identities (F-LIB022)",
                  "tests": "has name or identities"
                }
              ],
              "subsets": [
                {
                  "field": "inboxes",
                  "assert": [
                    {
                      "id": "GOBL-DK-OIOUBL-BILL-STATUS-03",
                      "desc": "customer inboxes are required (F-APR012)",
                      "tests": "present"
                    }
                  ]
                }
              ]
            },
            {
              "field": "issuer",
              "assert": [
                {
                  "id": "GOBL-DK-OIOUBL-BILL-STATUS-10",
                  "desc": "issuer must have a tax ID or identities when set (F-APR048)",
                  "tests": "has tax id or identities"
                },
                {
                  "id": "GOBL-DK-OIOUBL-BILL-STATUS-11",
                  "desc": "issuer must have a name or identities when set (F-LIB022)",
                  "tests": "has name or identities"
                }
              ],
              "subsets": [
                {
                  "field": "inboxes",
                  "assert": [
                    {
                      "id": "GOBL-DK-OIOUBL-BILL-STATUS-09",
                      "desc": "issuer inboxes are required when issuer is set (F-APR047)",
                      "tests": "present"
                    }
                  ]
                }
              ]
            },
            {
              "field": "lines",
              "subsets": [
                {
                  "each": true,
                  "subsets": [
                    {
                      "field": "doc",
                      "assert": [
                        {
                          "id": "GOBL-DK-OIOUBL-BILL-STATUS-04",
                          "desc": "line document reference is required for a response (cf. F-APR016, F-APR025)",
                          "tests": "present"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
