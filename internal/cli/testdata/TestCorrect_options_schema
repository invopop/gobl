{
    "$comment": "Generated dynamically for es",
    "$defs": {
        "Code": {
            "$id": "https://gobl.org/draft-0/cbc/code",
            "description": "Alphanumerical text identifier with upper-case letters and limits on using\nspecial characters or whitespace to separate blocks.",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[A-ZÑa-z0-9]+([\\.\\-\\:/,_\\\u0026 ]?[A-ZÑa-z0-9]+)*$",
            "title": "Code",
            "type": "string"
        },
        "CorrectionOptions": {
            "description": "CorrectionOptions defines a structure used to pass configuration options to correct a previous invoice.",
            "properties": {
                "copy_tax": {
                    "description": "CopyTax when true will copy the tax totals from the previous document to the\npreceding document data.",
                    "title": "Copy Tax Totals",
                    "type": "boolean"
                },
                "issue_date": {
                    "$ref": "https://gobl.org/draft-0/cal/date",
                    "description": "When the new corrective invoice's issue date should be set to.",
                    "title": "Issue Date"
                },
                "reason": {
                    "description": "Human readable reason for the corrective operation.",
                    "title": "Reason",
                    "type": "string"
                },
                "series": {
                    "$ref": "https://gobl.org/draft-0/cbc/code",
                    "description": "Series to assign to the new corrective invoice.",
                    "title": "Series"
                },
                "stamps": {
                    "description": "Stamps of the previous document to include in the preceding data.",
                    "items": {
                        "$ref": "https://gobl.org/draft-0/head/stamp"
                    },
                    "title": "Stamps",
                    "type": "array"
                },
                "type": {
                    "$ref": "https://gobl.org/draft-0/cbc/key",
                    "default": "credit-note",
                    "description": "The type of corrective invoice to produce.",
                    "oneOf": [
                        {
                            "const": "credit-note",
                            "description": "Reflects a refund either partial or complete of the preceding document. A \ncredit note effectively *extends* the previous document.",
                            "title": "Credit Note"
                        },
                        {
                            "const": "corrective",
                            "description": "Corrected invoice that completely *replaces* the preceding document.",
                            "title": "Corrective"
                        },
                        {
                            "const": "debit-note",
                            "description": "An additional set of charges to be added to the preceding document.",
                            "title": "Debit Note"
                        }
                    ],
                    "title": "Type"
                }
            },
            "recommended": [
                "series"
            ],
            "required": [
                "type"
            ],
            "type": "object"
        },
        "Date": {
            "$id": "https://gobl.org/draft-0/cal/date",
            "description": "Civil date in simplified ISO format, like 2021-05-26",
            "format": "date",
            "title": "Date",
            "type": "string"
        },
        "Extensions": {
            "$id": "https://gobl.org/draft-0/tax/extensions",
            "description": "Extensions is a map of extension keys to values.",
            "patternProperties": {
                "^(?:[a-z]|[a-z0-9][a-z0-9-+]*[a-z0-9])$": {
                    "$ref": "https://gobl.org/draft-0/cbc/code"
                }
            },
            "type": "object"
        },
        "Key": {
            "$id": "https://gobl.org/draft-0/cbc/key",
            "description": "Text identifier to be used instead of a code for a more verbose but readable identifier.",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^(?:[a-z]|[a-z0-9][a-z0-9-+]*[a-z0-9])$",
            "title": "Key",
            "type": "string"
        },
        "Stamp": {
            "$id": "https://gobl.org/draft-0/head/stamp",
            "description": "Stamp defines an official seal of approval from a third party like a governmental agency or intermediary and should thus be included in any official envelopes.",
            "properties": {
                "prv": {
                    "$ref": "https://gobl.org/draft-0/cbc/key",
                    "description": "Identity of the agency used to create the stamp usually defined by each region.",
                    "title": "Provider"
                },
                "val": {
                    "description": "The serialized stamp value generated for or by the external agency",
                    "title": "Value",
                    "type": "string"
                }
            },
            "required": [
                "prv",
                "val"
            ],
            "type": "object"
        }
    },
    "$id": "https://gobl.org/draft-0/bill/correction-options?tax_regime=es",
    "$ref": "#/$defs/CorrectionOptions",
    "$schema": "https://json-schema.org/draft/2020-12/schema"
}